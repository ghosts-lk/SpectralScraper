# SpectralScraper Configuration

# ==================== API KEYS ====================
CLEARBIT_API_KEY=your_clearbits_api_key_here
HUNTER_IO_API_KEY=your_hunter_io_api_key_here
LINKEDIN_API_KEY=your_linkedin_api_key_here
GITHUB_API_KEY=your_github_api_key_here
TWITTER_API_KEY=your_twitter_api_key_here

# ==================== DATABASE ====================
DATABASE_URL=sqlite://./data/spectral.db
REDIS_URL=redis://localhost:6379

# ==================== CACHING ====================
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_BACKEND=memory  # 'memory' or 'redis'

# ==================== COMPLIANCE ====================
GDPR_ENABLED=true
CCPA_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30
DELAY_BETWEEN_REQUESTS_MS=1000
RESPECT_ROBOTS_TXT=true

# ==================== ENRICHMENT ====================
VALIDATE_EMAILS=true
ENRICH_WITH_SOCIAL=true
ENRICH_WITH_COMPANY_DATA=true
ENRICH_WITH_PHONE_DATA=true
MAX_PARALLEL_ENRICHMENT_REQUESTS=5
SCORE_THRESHOLD=30

# ==================== WYRM INTEGRATION ====================
WYRM_ENABLED=false
WYRM_PROJECT_PATH=/path/to/project
WYRM_SYNC_TO_DATA_LAKE=true
WYRM_CATEGORY=leads
WYRM_TAGS=prospect,outbound

# ==================== LOGGING ====================
LOG_LEVEL=info  # 'error' | 'warn' | 'info' | 'debug'
LOG_FORMAT=json  # 'json' | 'text'

# ==================== ENVIRONMENT ====================
NODE_ENV=production  # 'development' | 'production'
PORT=3000
